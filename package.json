{
  "name": "fm2k",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @fm2k/web dev",
    "build": "pnpm --filter @fm2k/web build",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:mutation": "pnpm --filter @fm2k/engine test:mutation",
    "test:mutation:all": "pnpm -r test:mutation",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}