{
  "name": "fm2k",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @fm2k/web dev",
    "build": "pnpm --filter @fm2k/web build",
    "test": "pnpm --filter @fm2k/engine test",
    "test:coverage": "pnpm --filter @fm2k/engine test:coverage",
    "test:mutation": "pnpm --filter @fm2k/engine test:mutation",
    "lint": "pnpm -r lint",
    "check": "pnpm lint && pnpm test",
    "preinstall": "pnpm check"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": []
  }
}