{
  "name": "@fm2k/engine",
  "version": "1.0.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:calibration": "vitest run --config vitest.calibration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "stryker run",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint --fix src/**/*.ts",
    "generate-players": "tsx scripts/generate-players.ts",
    "populate-teams": "tsx scripts/populate-teams.ts",
    "calibration-report": "tsx scripts/calibration-report.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fm2k/lineup": "workspace:*",
    "@fm2k/match": "workspace:*",
    "@fm2k/names": "workspace:*",
    "@fm2k/players": "workspace:*",
    "@fm2k/state": "workspace:*",
    "@fm2k/timeline": "workspace:*",
    "@fm2k/valuation": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
